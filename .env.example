# ============================================================
# Slack Agent Bot - 環境變數設定
# ============================================================
# 複製這個檔案為 .env，然後填入你的值
# cp .env.example .env

# --- Slack 設定 ---
# 1. 到 https://api.slack.com/apps 建立一個新 App
# 2. 開啟 Socket Mode（Settings > Socket Mode > Enable）
# 3. 取得 App-Level Token（Settings > Basic Information > App-Level Tokens）
#    - 建立 token 時勾選 connections:write scope
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxxxx

# 4. 到 OAuth & Permissions，加入以下 Bot Token Scopes:
#    - app_mentions:read （讀取 @mention）
#    - chat:write        （發送訊息）
#    - im:history         （讀取 DM）
#    - im:read            （讀取 DM channel 資訊）
#    - im:write           （發送 DM）
# 5. Install App to Workspace，取得 Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx

# 6. 到 Event Subscriptions > Subscribe to bot events，加入:
#    - app_mention
#    - message.im

# --- OpenAI API ---
# 到 https://platform.openai.com/api-keys 取得 API key
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# 模型選擇（可選）
# gpt-4o     → 最強，較貴
# gpt-4o-mini → 便宜很多，日常用途夠了
OPENAI_MODEL=gpt-4o

# --- 你的 Slack User ID ---
# 在 Slack 裡點自己的頭像 > Profile > 三個點 > Copy member ID
# 用來接收每日摘要和提醒通知
MY_SLACK_USER_ID=U0XXXXXXXXX

# --- 選填 ---
# 每日摘要發送時間（24 小時制，預設 9）
DAILY_SUMMARY_HOUR=9
